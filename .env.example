GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

SYSTEM_PROMPT_PATH=prompts/system_prompt.md
MAX_TURNS_MEMORY=6

# Storage: local | r2
STORAGE_PROVIDER=local

# Cloudflare R2 (chi can khi STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_OBJECT_KEY=knowledge_base.json
# Optional: tu custom endpoint neu can. Mac dinh: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_REGION=auto
